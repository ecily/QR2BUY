MONGODB_URI=mongodb+srv://qr2buy_app:1nEtVVQ1YZjPLbOO@cluster0.ykgnxjl.mongodb.net/qr2buy?retryWrites=true&w=majority&appName=Cluster0

CORS_ORIGIN=http://localhost:5173
